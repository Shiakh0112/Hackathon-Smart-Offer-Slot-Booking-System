# ===== BACKEND (.NET 8) =====
# Copy to: backend/OfferSlotBooking/appsettings.json

# PostgreSQL (default)
DB_CONNECTION=Host=localhost;Database=offerslotdb;Username=postgres;Password=yourpassword
DB_PROVIDER=postgres

# OR SQL Server
# DB_CONNECTION=Server=localhost;Database=OfferSlotDb;Trusted_Connection=True;TrustServerCertificate=True
# DB_PROVIDER=sqlserver

# JWT Secret (min 32 chars)
JWT_KEY=YourSuperSecretKeyThatIsAtLeast32CharactersLong!
JWT_ISSUER=OfferSlotBooking
JWT_AUDIENCE=OfferSlotBookingUsers

# ===== FRONTEND (React + Vite) =====
# Copy to: frontend/offer-slot-booking/.env
VITE_API_URL=http://localhost:5000
